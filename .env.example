# Core
SECRET_KEY=change-me-use-a-long-random-value
APP_NAME=HEICFlow
PUBLIC_BASE_URL=https://your-domain.com
CONTACT_EMAIL=support@your-domain.com
DATABASE_URL=sqlite:///app.db

# Upload and abuse protection
MAX_CONTENT_LENGTH_BYTES=62914560
MAX_FILE_SIZE_BYTES=10485760
GUEST_MAX_FILES_PER_BATCH=5
MAX_FILES_PER_BATCH=10
GUEST_DAILY_FILES=5
GUEST_DAILY_MB=25
GUEST_IP_DAILY_FILES=50
GUEST_IP_DAILY_MB=250
FREE_MONTHLY_QUOTA=50

# Google AdSense (leave empty until approved)
ADSENSE_CLIENT=
ADSENSE_SLOT_TOP=
ADSENSE_SLOT_AFTER_CONVERT=
ADSENSE_SLOT_FOOTER=

# Google OAuth optional free account login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Paddle optional worldwide payments
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_CLIENT_TOKEN=

# ePayco optional Colombia payments
EPAYCO_PUBLIC_KEY=
EPAYCO_PRIVATE_KEY=
EPAYCO_P_CUST_ID_CLIENTE=
EPAYCO_P_KEY=
EPAYCO_TEST=true

# Plans. price_id is required by the current Paddle flow. For ePayco, also set epayco_plan_code and amount.
PLANS_JSON=[{"name":"Pro","price_id":"pri_replace_me","monthly_label":"$19.900 COP/mo","monthly_quota":1000,"epayco_plan_code":"pro_monthly","epayco_amount_cop":19900},{"name":"Business","price_id":"pri_replace_me_2","monthly_label":"$99.000 COP/mo","monthly_quota":6000,"epayco_plan_code":"business_monthly","epayco_amount_cop":99000}]
